---
/**
 * Prose — shared typography wrapper for long-form legal/about content.
 *
 * Scoped styles target slotted children via :global() (slotted content isn't
 * hashed by Astro's scoping). Keeps the 4 trust pages visually consistent
 * without pulling in @tailwindcss/typography, and only ships on pages that use
 * it. All colors reference the theme tokens so both themes work.
 */
---

<div class="prose">
  <slot />
</div>

<style>
  .prose :global(h2) {
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-fg);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h2:first-child) {
    margin-top: 0;
  }
  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-fg);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(p) {
    color: var(--color-fg-muted);
    line-height: 1.7;
    margin-top: 0;
    margin-bottom: 1rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    color: var(--color-fg-muted);
    line-height: 1.7;
    margin: 0 0 1rem;
    padding-left: 1.25rem;
  }
  .prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose :global(li::marker) {
    color: var(--color-fg-subtle);
  }
  .prose :global(strong),
  .prose :global(b) {
    color: var(--color-fg);
    font-weight: 600;
  }
  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) {
    opacity: 0.85;
  }
  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.875em;
    background: var(--color-bg-muted);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }
</style>
