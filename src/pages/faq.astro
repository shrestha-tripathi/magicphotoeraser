---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, absoluteUrl } from "../site.config";
import { faqs, buildFaqSchema } from "../data/faqs";

const title = "FAQ";
const description = `Frequently asked questions about ${site.name} — the free, fully private, on-device photo object eraser. No upload, no signup, no watermark.`;

const faqSchema = buildFaqSchema();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
    { "@type": "ListItem", position: 2, name: "FAQ", item: absoluteUrl("/faq") },
  ],
};
---

<Layout title={title} description={description} jsonLd={[faqSchema, breadcrumbSchema]}>
  <Header />

  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <nav class="text-sm text-[var(--color-fg-subtle)]" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--color-fg)]">Home</a>
      <span class="px-1.5">/</span>
      <span class="text-[var(--color-fg-muted)]">FAQ</span>
    </nav>

    <header class="mt-6">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Frequently asked questions
      </h1>
      <p class="mt-4 text-lg text-[var(--color-fg-muted)]">
        How the free, private, on-device object eraser works — and why your
        photos never leave your device.
      </p>
    </header>

    <div class="mt-10 space-y-3">
      {
        faqs.map((f, i) => (
          <details
            class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-5 [&[open]]:border-[color-mix(in_srgb,var(--color-accent)_40%,transparent)]"
            open={i === 0}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 font-semibold text-[var(--color-fg)] marker:hidden">
              {f.q}
              <svg
                class="size-5 shrink-0 text-[var(--color-fg-subtle)] transition-transform group-open:rotate-180"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="pb-4 leading-relaxed text-[var(--color-fg-muted)]">{f.a}</p>
          </details>
        ))
      }
    </div>

    {/* CTA */}
    <div class="mt-12 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-6 py-10 text-center">
      <h2 class="text-2xl font-bold tracking-tight">Ready to erase something?</h2>
      <p class="mx-auto mt-3 max-w-md text-[var(--color-fg-muted)]">
        It's free, runs in your browser, and your photo never gets uploaded.
      </p>
      <a
        href="/app/"
        class="mt-6 inline-flex rounded-lg bg-[var(--color-accent)] px-7 py-3 font-semibold text-[var(--color-accent-fg)] transition-opacity hover:opacity-90"
      >
        Open the eraser
      </a>
    </div>
  </main>

  <Footer />
</Layout>
