---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Page not found"
  description="This page doesn't exist. Head back and erase objects from a photo instead."
  path="/404/"
  noindex={true}
>
  <Header />

  <main class="mx-auto flex max-w-[680px] flex-col items-center px-6 py-24 md:py-32 text-center">
    <p class="text-6xl md:text-7xl font-bold tracking-tight text-[var(--color-accent)]">404</p>
    <h1 class="mt-4 text-2xl md:text-3xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-4 text-[var(--color-fg-muted)]">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/app/"
        class="rounded-lg bg-[var(--color-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--color-accent-fg)] transition-opacity hover:opacity-90"
      >
        Open the eraser
      </a>
      <a
        href="/"
        class="rounded-lg border border-[var(--color-border)] px-5 py-2.5 text-sm font-medium text-[var(--color-fg-muted)] transition-colors hover:bg-[var(--color-bg-muted)] hover:text-[var(--color-fg)]"
      >
        Go home
      </a>
    </div>
  </main>

  <Footer />
</Layout>
