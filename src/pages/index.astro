---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroDemo from "../components/HeroDemo.astro";
import MechanismAnimation from "../components/MechanismAnimation.astro";
import { site } from "../site.config";
import { faqs, buildFaqSchema } from "../data/faqs";
import { teaserRows, COMPETITORS, type Verdict } from "../data/comparison";

/* ---- Switch Promise grid: 7 architectural moats (incumbent-displacement) ---- */
const promises = [
  {
    pain: "Uploads your photo to a server",
    answer: "Runs 100% on your device",
    detail:
      "The AI model executes inside your browser via WebGPU (WASM fallback). Your photo never touches a network. Upload-based tools can't match this without abandoning their business model.",
    // Lucide "cloud-off"
    icon: `<path d="m2 2 20 20"/><path d="M5.782 5.782A7 7 0 0 0 9 19h8.5a4.5 4.5 0 0 0 1.307-.193"/><path d="M21.532 16.5A4.5 4.5 0 0 0 17.5 10h-1.79"/><path d="M9.21 4.21A6.67 6.67 0 0 1 12 4a6.5 6.5 0 0 1 6.5 6.5"/>`,
  },
  {
    pain: "Softens your whole image",
    answer: "Keeps your photo pixel-sharp",
    detail:
      "We process only the region you brushed and composite it back into your full-resolution original. Servers downscale the whole image to save compute — we don't have to.",
    // Lucide "scan"
    icon: `<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 12h10"/>`,
  },
  {
    pain: "Paywalls HD output",
    answer: "Free forever, full resolution",
    detail:
      "Zero marginal cost on-device means we never pay a GPU bill per erase. Every competitor does — so they must paywall HD or watermark to survive. We structurally don't.",
    // Lucide "infinity"
    icon: `<path d="M18.178 8c5.096 0 5.096 8 0 8-5.095 0-7.133-8-12.739-8-4.585 0-4.585 8 0 8 5.606 0 7.644-8 12.74-8z"/>`,
  },
  {
    pain: "Stamps a watermark",
    answer: "No watermark, ever",
    detail:
      "Download the full-resolution result clean — no badge, no logo. EXIF metadata (including GPS) is stripped on the way out for your privacy.",
    // Lucide "sparkles"
    icon: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>`,
  },
  {
    pain: "Demands an account",
    answer: "No signup, no login",
    detail:
      "Open the page and start erasing. No email, no password, no credits. There's no account system because there's no server to hold an account on.",
    // Lucide "user-x"
    icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" x2="22" y1="8" y2="13"/><line x1="22" x2="17" y1="8" y2="13"/>`,
  },
  {
    pain: "Needs a constant connection",
    answer: "Works offline after first load",
    detail:
      "The model caches on your device the first time you erase. After that you can keep working with no internet at all — impossible for any server-side tool.",
    // Lucide "wifi-off"
    icon: `<path d="M12 20h.01"/><path d="M8.5 16.429a5 5 0 0 1 7 0"/><path d="M5 12.859a10 10 0 0 1 5.17-2.69"/><path d="M19 12.859a10 10 0 0 0-2.007-1.523"/><path d="M2 8.82a15 15 0 0 1 4.177-2.643"/><path d="M22 8.82a15 15 0 0 0-11.288-3.764"/><path d="m2 2 20 20"/>`,
  },
  {
    pain: "Closed-source black box",
    answer: "Open source — inspect it",
    detail:
      "The whole thing is on GitHub. See exactly what runs on your photos. A closed-source vendor can't open up without handing rivals their edge.",
    // Lucide "github"
    icon: `<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C5 2 4 2 4 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 3 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>`,
  },
];

/* ---- WebApplication schema (home) ---- */
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": `${site.url}/#webapp`,
  name: site.name,
  url: site.url,
  description: site.description,
  applicationCategory: "MultimediaApplication",
  applicationSubCategory: "Photo Editor",
  operatingSystem: "Any (Chrome, Firefox, Safari, Edge)",
  browserRequirements: "Requires a modern browser; WebGPU recommended, WASM fallback supported",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  featureList: [
    "Remove objects from photos in the browser",
    "100% on-device — no upload",
    "Full-resolution HD output, no watermark",
    "Free forever, no signup",
    "Works offline after first load",
  ],
  isAccessibleForFree: true,
  publisher: { "@id": `${site.url}/#organization` },
};

const faqSchema = buildFaqSchema();

/* Verdict → icon for the teaser table */
function verdictIcon(v: Verdict) {
  if (v === true)
    return {
      cls: "text-[var(--color-success)]",
      svg: `<polyline points="20 6 9 17 4 12"/>`,
      label: "Yes",
    };
  if (v === "partial")
    return {
      cls: "text-amber-500",
      svg: `<line x1="5" y1="12" x2="19" y2="12"/>`,
      label: "Partial",
    };
  return {
    cls: "text-[var(--color-fg-subtle)]",
    svg: `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`,
    label: "No",
  };
}
---

<Layout jsonLd={[webAppSchema, faqSchema]}>
  <Header />

  <main>
    {/* ============================ HERO ============================ */}
    <section class="mx-auto max-w-6xl px-4 pt-12 pb-8 sm:px-6 sm:pt-20">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
        <div>
          <span
            class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-3 py-1 text-sm text-[var(--color-fg-muted)]"
          >
            <span class="size-2 rounded-full bg-[var(--color-accent)]"></span>
            100% in your browser · nothing uploaded
          </span>

          <h1 class="mt-5 text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl">
            Erase anything from a photo —
            <span class="relative inline-block whitespace-nowrap">
              <span class="relative z-10">without uploading it.</span>
              <svg
                class="absolute -bottom-1 left-0 z-0 w-full"
                viewBox="0 0 340 12"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <path
                  d="M2 8C60 3 120 3 170 6C220 9 280 9 338 4"
                  stroke="var(--color-accent)"
                  stroke-width="8"
                  stroke-linecap="round"
                  opacity="0.85"></path>
              </svg>
            </span>
          </h1>

          <p class="mt-5 max-w-xl text-lg text-[var(--color-fg-muted)]">
            Remove objects, people, text, or watermarks from any picture — right
            in your browser. Upload-based tools like cleanup.pictures send your
            photo to a server and paywall the sharp version.
            <span class="font-medium text-[var(--color-fg)]"
              >We do it on your device, in full resolution, for free.</span
            >
          </p>

          <div class="mt-7 flex flex-wrap items-center gap-3">
            <a
              href="/app"
              class="rounded-lg bg-[var(--color-accent)] px-6 py-3 font-semibold text-[var(--color-accent-fg)] transition-opacity hover:opacity-90"
            >
              Erase a photo — free
            </a>
            <a
              href="/how-it-works"
              class="rounded-lg border border-[var(--color-border)] px-6 py-3 font-semibold text-[var(--color-fg)] transition-colors hover:bg-[var(--color-bg-muted)]"
            >
              How it works
            </a>
          </div>

          {/* Trust chips — one killer claim + two supporters */}
          <ul class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
            <li
              class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 font-semibold text-[var(--color-fg)]"
              style="background-color: color-mix(in srgb, var(--color-accent) 15%, transparent);"
            >
              <svg class="text-[var(--color-accent)]" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              Photos never leave your device
            </li>
            <li class="inline-flex items-center gap-1.5 text-[var(--color-fg-muted)]">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18.178 8c5.096 0 5.096 8 0 8-5.095 0-7.133-8-12.739-8-4.585 0-4.585 8 0 8 5.606 0 7.644-8 12.74-8z"/></svg>
              Free forever
            </li>
            <li class="inline-flex items-center gap-1.5 text-[var(--color-fg-muted)]">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              No signup · no watermark
            </li>
          </ul>
        </div>

        {/* Visual proof */}
        <div class="lg:pl-4">
          <HeroDemo />
          <p class="mt-3 text-center text-sm text-[var(--color-fg-subtle)]">
            Drag the slider — the photobomber's gone, the beach stays sharp.
          </p>
        </div>
      </div>
    </section>

    {/* ==================== SWITCH PROMISE GRID ==================== */}
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
          Seven things upload-based erasers structurally can't do
        </h2>
        <p class="mt-4 text-[var(--color-fg-muted)]">
          Not because their teams are lazy — because their architecture runs on
          a server you pay for. Ours runs on the device in your hand.
        </p>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          promises.map((p) => (
            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-6">
              <div class="flex items-center gap-3">
                <span
                  class="inline-flex size-10 shrink-0 items-center justify-center rounded-lg text-[var(--color-accent)]"
                  style="background-color: color-mix(in srgb, var(--color-accent) 12%, transparent); border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);"
                  aria-hidden="true"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={p.icon}
                  />
                </span>
                <p class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-subtle)] line-through decoration-[var(--color-danger)]/60">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-danger)" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" class="no-underline"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  {p.pain}
                </p>
              </div>
              <h3 class="mt-4 text-lg font-semibold text-[var(--color-fg)]">
                {p.answer}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg-muted)]">
                {p.detail}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    {/* ==================== HOW IT WORKS / MECHANISM ==================== */}
    <section
      id="how"
      class="border-y border-[var(--color-border)] bg-[var(--color-bg-subtle)]"
    >
      <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2">
        <div>
          <span class="text-sm font-semibold uppercase tracking-wide text-[var(--color-accent)]">
            Why it stays sharp
          </span>
          <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
            We only touch the part you brushed
          </h2>
          <p class="mt-4 text-[var(--color-fg-muted)]">
            Free erasers shrink your entire photo to a tiny size to run the AI,
            then blow it back up — softening everything. We do the opposite:
          </p>
          <ol class="mt-6 space-y-4">
            <li class="flex gap-3">
              <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-[var(--color-accent-fg)]">1</span>
              <p class="text-sm text-[var(--color-fg-muted)]"><b class="text-[var(--color-fg)]">Brush</b> over the object you want gone.</p>
            </li>
            <li class="flex gap-3">
              <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-[var(--color-accent-fg)]">2</span>
              <p class="text-sm text-[var(--color-fg-muted)]"><b class="text-[var(--color-fg)]">We crop just that region</b>, run the inpainting model on it, and let the rest of your image sit untouched.</p>
            </li>
            <li class="flex gap-3">
              <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-[var(--color-accent-fg)]">3</span>
              <p class="text-sm text-[var(--color-fg-muted)]"><b class="text-[var(--color-fg)]">We composite the patch back</b> into your full-resolution original with feathered edges. HD stays HD.</p>
            </li>
          </ol>
          <a href="/how-it-works" class="mt-7 inline-flex items-center gap-1.5 font-semibold text-[var(--color-accent)] hover:underline">
            Read the full breakdown
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div>
          <MechanismAnimation />
        </div>
      </div>
    </section>

    {/* ==================== COMPARISON TEASER ==================== */}
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
          How we compare
        </h2>
        <p class="mt-4 text-[var(--color-fg-muted)]">
          The big erasers are good — but they upload your photo and paywall the
          sharp result, because they pay for servers. Here's the short version.
        </p>
      </div>

      <div class="mx-auto mt-10 max-w-4xl overflow-hidden rounded-xl border border-[var(--color-border)]">
        {/* Desktop table */}
        <table class="hidden w-full border-collapse text-sm sm:table">
          <thead>
            <tr class="border-b border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
              <th class="px-5 py-4 text-left font-semibold">Feature</th>
              {COMPETITORS.map((c) => (
                <th class="px-3 py-4 text-center font-medium text-[var(--color-fg-muted)]">{c}</th>
              ))}
              <th
                class="px-3 py-4 text-center font-bold text-[var(--color-fg)]"
                style="background-color: color-mix(in srgb, var(--color-accent) 16%, transparent);"
              >
                {site.name}
              </th>
            </tr>
          </thead>
          <tbody>
            {
              teaserRows.map((row) => (
                <tr class="border-b border-[var(--color-border)] last:border-0">
                  <td class="px-5 py-4">
                    <span class="font-medium text-[var(--color-fg)]">{row.feature}</span>
                  </td>
                  {row.others.map((v) => {
                    const ic = verdictIcon(v);
                    return (
                      <td class="px-3 py-4 text-center">
                        <span class={`inline-flex ${ic.cls}`} aria-label={ic.label}>
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={ic.svg} />
                        </span>
                      </td>
                    );
                  })}
                  <td
                    class="px-3 py-4 text-center"
                    style="background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);"
                  >
                    <span class="inline-flex text-[var(--color-accent)]" aria-label="Yes">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>

        {/* Mobile cards */}
        <div class="divide-y divide-[var(--color-border)] sm:hidden">
          {
            teaserRows.map((row) => (
              <div class="px-5 py-4">
                <h3 class="text-base font-semibold text-[var(--color-fg)]">{row.feature}</h3>
                <ul class="mt-3 space-y-2 text-sm">
                  {row.others.map((v, i) => {
                    const ic = verdictIcon(v);
                    return (
                      <li class="flex items-center justify-between">
                        <span class="text-[var(--color-fg-muted)]">{COMPETITORS[i]}</span>
                        <span class={`inline-flex items-center gap-1 ${ic.cls}`}>
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={ic.svg} />
                          {ic.label}
                        </span>
                      </li>
                    );
                  })}
                  <li class="flex items-center justify-between font-semibold">
                    <span class="text-[var(--color-fg)]">{site.name}</span>
                    <span class="inline-flex items-center gap-1 text-[var(--color-accent)]">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      Yes
                    </span>
                  </li>
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-7 text-center">
        <a
          href="/compare"
          class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-5 py-2.5 font-semibold text-[var(--color-fg)] transition-colors hover:bg-[var(--color-bg-muted)]"
        >
          See the full comparison
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    {/* ==================== FAQ ==================== */}
    <section
      id="faq"
      class="border-t border-[var(--color-border)] bg-[var(--color-bg-subtle)]"
    >
      <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
        <div class="text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            Frequently asked questions
          </h2>
          <p class="mt-4 text-[var(--color-fg-muted)]">
            Everything about how the private, on-device eraser works.
          </p>
        </div>

        <div class="mt-10 space-y-3">
          {
            faqs.map((f, i) => (
              <details
                class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-5 [&[open]]:border-[color-mix(in_srgb,var(--color-accent)_40%,transparent)]"
                open={i === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 font-semibold text-[var(--color-fg)] marker:hidden">
                  {f.q}
                  <svg
                    class="size-5 shrink-0 text-[var(--color-fg-subtle)] transition-transform group-open:rotate-180"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </summary>
                <p class="pb-4 text-[var(--color-fg-muted)] leading-relaxed">
                  {f.a}
                </p>
              </details>
            ))
          }
        </div>

        <div class="mt-10 text-center">
          <a
            href="/faq"
            class="text-sm font-medium text-[var(--color-accent)] hover:underline"
          >
            See all FAQs →
          </a>
        </div>
      </div>
    </section>

    {/* ==================== FINAL CTA ==================== */}
    <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div
        class="relative overflow-hidden rounded-2xl border border-[var(--color-border)] px-6 py-14 text-center"
        style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 12%, var(--color-bg)) 0%, var(--color-bg) 60%);"
      >
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
          Erase it. Keep it private. Keep it sharp.
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-[var(--color-fg-muted)]">
          No upload, no signup, no watermark, no cost. Your photo never leaves
          your browser.
        </p>
        <a
          href="/app"
          class="mt-8 inline-flex rounded-lg bg-[var(--color-accent)] px-7 py-3.5 font-semibold text-[var(--color-accent-fg)] transition-opacity hover:opacity-90"
        >
          Open the eraser — free forever
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
