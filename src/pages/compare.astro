---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, absoluteUrl } from "../site.config";
import { comparisonRows, COMPETITORS, type Verdict } from "../data/comparison";

const title = "Compare";
const description = `${site.name} vs cleanup.pictures, Pixlr & Photoshop — why a free, on-device eraser keeps your photo private and full-resolution while others paywall HD.`;

/* Verdict → icon style + label */
function verdictIcon(v: Verdict) {
  if (v === true)
    return { cls: "text-[var(--color-success)]", svg: `<polyline points="20 6 9 17 4 12"/>`, label: "Yes" };
  if (v === "partial")
    return { cls: "text-amber-500", svg: `<line x1="5" y1="12" x2="19" y2="12"/>`, label: "Partial" };
  return { cls: "text-[var(--color-fg-subtle)]", svg: `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`, label: "No" };
}

/* BreadcrumbList schema */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
    { "@type": "ListItem", position: 2, name: "Compare", item: absoluteUrl("/compare") },
  ],
};
---

<Layout title={title} description={description} jsonLd={[breadcrumbSchema]}>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <nav class="text-sm text-[var(--color-fg-subtle)]" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[var(--color-fg)]">Home</a>
      <span class="px-1.5">/</span>
      <span class="text-[var(--color-fg-muted)]">Compare</span>
    </nav>

    <header class="mt-6 max-w-2xl">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        {site.name} vs the upload-based erasers
      </h1>
      <p class="mt-4 text-lg text-[var(--color-fg-muted)]">
        cleanup.pictures, Pixlr, and Photoshop are capable tools. But they send
        your photo to a server and paywall the sharp result, because someone has
        to pay the GPU bill. Running on your device removes that bill — so we can
        be private, full-resolution, and free at the same time.
      </p>
    </header>

    {/* Legend */}
    <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-[var(--color-fg-muted)]">
      <span class="inline-flex items-center gap-1.5">
        <svg class="text-[var(--color-success)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Yes
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg class="text-amber-500" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Partial / with caveat
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg class="text-[var(--color-fg-subtle)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        No
      </span>
    </div>

    {/* Desktop table */}
    <div class="mt-8 hidden overflow-hidden rounded-xl border border-[var(--color-border)] md:block">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="border-b border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
            <th class="px-5 py-4 text-left font-semibold">Feature</th>
            {
              COMPETITORS.map((c) => (
                <th class="px-3 py-4 text-center font-medium text-[var(--color-fg-muted)]">{c}</th>
              ))
            }
            <th
              class="px-3 py-4 text-center font-bold text-[var(--color-fg)]"
              style="background-color: color-mix(in srgb, var(--color-accent) 16%, transparent);"
            >
              {site.name}
            </th>
          </tr>
        </thead>
        <tbody>
          {
            comparisonRows.map((row) => (
              <tr class="border-b border-[var(--color-border)] align-top last:border-0">
                <td class="px-5 py-4">
                  <span class="font-medium text-[var(--color-fg)]">{row.feature}</span>
                  <p class="mt-1 text-xs text-[var(--color-fg-subtle)]">{row.why}</p>
                </td>
                {row.others.map((v, i) => {
                  const ic = verdictIcon(v);
                  const caveat = row.notes?.[i];
                  return (
                    <td class="px-3 py-4 text-center">
                      <span class={`inline-flex ${ic.cls}`} aria-label={ic.label} title={caveat ?? ic.label}>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={ic.svg} />
                      </span>
                      {caveat && <p class="mt-1 text-[11px] leading-tight text-[var(--color-fg-subtle)]">{caveat}</p>}
                    </td>
                  );
                })}
                <td
                  class="px-3 py-4 text-center"
                  style="background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);"
                >
                  <span
                    class={`inline-flex ${row.us ? "text-[var(--color-accent)]" : "text-[var(--color-fg-subtle)]"}`}
                    aria-label={row.us ? "Yes" : "No (yet)"}
                  >
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" set:html={row.us ? `<polyline points="20 6 9 17 4 12"/>` : `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`} />
                  </span>
                  {!row.us && row.note && (
                    <p class="mt-1 text-[11px] leading-tight text-[var(--color-accent)]">{row.note}</p>
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    {/* Mobile cards */}
    <div class="mt-8 space-y-3 md:hidden">
      {
        comparisonRows.map((row) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-5">
            <h2 class="text-base font-semibold text-[var(--color-fg)]">{row.feature}</h2>
            <p class="mt-1 text-xs text-[var(--color-fg-subtle)]">{row.why}</p>
            <ul class="mt-3 space-y-2 text-sm">
              {row.others.map((v, i) => {
                const ic = verdictIcon(v);
                const caveat = row.notes?.[i];
                return (
                  <li class="flex items-start justify-between gap-3">
                    <span class="text-[var(--color-fg-muted)]">{COMPETITORS[i]}</span>
                    <span class="flex flex-col items-end text-right">
                      <span class={`inline-flex items-center gap-1 ${ic.cls}`}>
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={ic.svg} />
                        {ic.label}
                      </span>
                      {caveat && <span class="mt-0.5 text-[11px] text-[var(--color-fg-subtle)]">{caveat}</span>}
                    </span>
                  </li>
                );
              })}
              <li class="flex items-start justify-between gap-3 border-t border-[var(--color-border)] pt-2 font-semibold">
                <span class="text-[var(--color-fg)]">{site.name}</span>
                <span class="flex flex-col items-end text-right">
                  <span class={`inline-flex items-center gap-1 ${row.us ? "text-[var(--color-accent)]" : "text-[var(--color-fg-subtle)]"}`}>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" set:html={row.us ? `<polyline points="20 6 9 17 4 12"/>` : `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`} />
                    {row.us ? "Yes" : "No (yet)"}
                  </span>
                  {!row.us && row.note && <span class="mt-0.5 text-[11px] font-normal text-[var(--color-accent)]">{row.note}</span>}
                </span>
              </li>
            </ul>
          </div>
        ))
      }
    </div>

    {/* Honesty note */}
    <p class="mt-8 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-5 py-4 text-sm text-[var(--color-fg-muted)]">
      <b class="text-[var(--color-fg)]">Where we're honest about a gap:</b>
      {" "}click-to-select (tap an object and we auto-select it) is a real
      strength of the bigger tools today. It's our next major release —
      on-device click-select that still never uploads your photo. Brush-select
      ships first. We'd rather show you the gap than hide it.
    </p>

    {/* CTA */}
    <div class="mt-10 text-center">
      <a
        href="/app/"
        class="inline-flex rounded-lg bg-[var(--color-accent)] px-7 py-3.5 font-semibold text-[var(--color-accent-fg)] transition-opacity hover:opacity-90"
      >
        Try the private eraser — free
      </a>
    </div>
  </main>

  <Footer />
</Layout>
