---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EraserApp from "../app/EraserApp.tsx";
import { site } from "../site.config";

const title = "The eraser";
const description = `Open a photo and erase anything from it — right in your browser. 100% on-device, free forever, no upload, no signup. ${site.name}.`;

// Phase 1 — the editor island mounts below.
//
// Still `noindex`: the tool needs JS to function (client:only React), so there
// is no meaningful static HTML for Google to rank — the marketing pages (/,
// /how-it-works, /compare, /faq) carry the SEO. Flip this to indexable once the
// eraser is feature-complete and we want /app itself to rank.
//
// client:only="react" (not client:load) because the editor is purely
// interactive and depends on browser-only APIs (createImageBitmap, Canvas,
// clipboard) — there is nothing to server-render, and SSR would throw on
// those globals at build time.
---

<Layout title={title} description={description} noindex>
  <div class="flex min-h-[100dvh] flex-col">
    <Header />
    <main class="flex-1">
      <EraserApp client:only="react" />
    </main>
    <Footer />
  </div>
</Layout>
