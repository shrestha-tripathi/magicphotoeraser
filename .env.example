# MagicPhotoEraser — environment variables (all optional; sensible defaults baked in)
#
# Copy to `.env` only if you need to override a default. A rebrand = edit `.env`,
# no code changes. Every value falls back to a real default in src/site.config.ts.

# Brand / metadata
PUBLIC_SITE_NAME="MagicPhotoEraser"
PUBLIC_SITE_TAGLINE="Erase anything from a photo — right in your browser."
PUBLIC_SITE_DESCRIPTION="Remove unwanted objects, people, text, or watermarks from any photo — 100% in your browser. No upload, no signup, no watermark. Your photos never leave your device."

# Canonical URL + domain. NOTE: never set these to a *.pages.dev value — the
# config guard rejects it and falls back to the real domain, but cleaner to omit.
PUBLIC_SITE_URL="https://magicphotoeraser.com"
PUBLIC_SITE_DOMAIN="magicphotoeraser.com"

# Trust-page details
PUBLIC_SITE_CONTACT_EMAIL="shrestha.tripathi@gmail.com"
PUBLIC_SITE_GITHUB_REPO="https://github.com/shrestha-tripathi/magicphotoeraser"
PUBLIC_SITE_JURISDICTION="India"

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX). Leave BLANK to
# disable analytics entirely. The snippet is only injected in production builds
# (localhost dev never pollutes the property). Defaults to the live property
# G-PPEGBCKZ4C in src/site.config.ts; only set this to override per-deploy.
PUBLIC_GA_MEASUREMENT_ID="G-PPEGBCKZ4C"
