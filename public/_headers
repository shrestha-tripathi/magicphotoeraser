# Cloudflare Pages headers for MagicPhotoEraser.
#
# 1. Cross-Origin Isolation (COOP/COEP) — REQUIRED for SharedArrayBuffer, which
#    the in-browser AI runtime (onnxruntime-web threaded WASM) needs for the
#    eraser. Cloudflare Pages serves these natively, so we do NOT need the
#    coi-serviceworker hack that GitHub Pages requires.
# 2. *.pages.dev preview deployments are marked noindex so only the real domain
#    gets indexed (avoids duplicate-content SEO dilution).

/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Force correct MIME on the legacy ICO. With nosniff set above, browsers will
# NOT sniff-correct a wrong Content-Type, so Windows pinned tabs / Firefox
# strict-MIME need this explicit rule to accept the multi-res favicon.ico.
/favicon.ico
  Content-Type: image/x-icon

# PWA manifest — some configs mis-serve .webmanifest; pin it.
/manifest.webmanifest
  Content-Type: application/manifest+json

# Preview deployments: keep them out of the index.
https://:project.pages.dev/*
  X-Robots-Tag: noindex
